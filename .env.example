APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GHL_API_BASE_URL=https://services.leadconnectorhq.com
# API Version header for most GHL calls (default 2021-07-28).
GHL_API_VERSION=2021-07-28
# Version header for invoice record-payment (default 2023-02-21 per GHL docs).
GHL_INVOICE_API_VERSION=2023-02-21
GHL_AGENCY_TOKEN=
# Set to true to use a Sub-Account "Private Integration" token (pit-...) from GHL Settings,
# stored in GHL_AGENCY_TOKEN, and skip OAuth/Marketplace install for API calls.
GHL_USE_PRIVATE_INTEGRATION=false
GHL_OAUTH_BASE_URL=https://marketplace.gohighlevel.com
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=http://127.0.0.1:8000/oauth/callback
GHL_SCOPES="locations.readonly contacts.readonly"
GHL_BRIDGE_WEBHOOK_SECRET=
# Embeber la app en GHL (Custom Page): por defecto (sin esta variable) se permiten orígenes típicos de GHL/LeadConnector.
# Lista separada por coma para reemplazar, p. ej. GHL_EMBED_FRAME_ANCESTORS=https://app.gohighlevel.com,https://app.midominio.com
# Usa GHL_EMBED_FRAME_ANCESTORS=false o deja el valor vacío en .env para desactivar cabeceras de iframe.

NMI_API_URL=https://secure.networkmerchants.com/api/transact.php
NMI_SECURITY_KEY=
NMI_WEBHOOK_SIGNING_KEY=
# When true, each GHL bridge webhook creates an NMI open invoice (add_invoice) so it appears in NMI (not a settled sale).
NMI_SYNC_GHL_INVOICES_TO_NMI=true
# When false, approved NMI webhook events only update Laravel status and skip syncing payment back to GHL.
NMI_SYNC_APPROVED_TO_GHL=true
# When true, approved payment webhooks from NMI will create a local order if not found.
NMI_AUTO_CREATE_FROM_WEBHOOK=false
# Opcional: si el contacto no tiene email en Laravel, NMI add_invoice usa este correo (si está vacío, hay default en config/services.php).
NMI_INVOICE_FALLBACK_EMAIL=

# iProcess -> Laravel bridge webhook
IPROCESS_WEBHOOK_SECRET=
# Optional fallback when iProcess payload does not include locationId
IPROCESS_DEFAULT_LOCATION_ID=
# Enable imported-payment sync path from /webhooks/nmi for iProcess-originated payments
IPROCESS_ENABLE_FROM_NMI_WEBHOOK=false
# When false, iProcess webhook resolves/creates contact but skips GHL invoice creation/payment sync.
IPROCESS_SYNC_INVOICE_TO_GHL=true
# When false, invoice is created in GHL but payment is not recorded as paid.
IPROCESS_MARK_INVOICE_PAID_IN_GHL=true
# Optional fallbacks used by GHL createInvoice when contact email/phone is missing or invalid.
IPROCESS_INVOICE_FALLBACK_EMAIL=
IPROCESS_INVOICE_FALLBACK_PHONE=
# Optional existing GHL contact id used when contacts.write is restricted by IAM
IPROCESS_FALLBACK_GHL_CONTACT_ID=
